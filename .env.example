# FinAlly — Environment Variable Template
# Copy this file to .env and fill in your values

# Required: Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/finally?sslmode=require

# Required: OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in GBM market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (testing/CI)
LLM_MOCK=false

# Set automatically by docker-compose — backend URL for Next.js rewrites proxy
# BACKEND_URL=http://backend:8000
